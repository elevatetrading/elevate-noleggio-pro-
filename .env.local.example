GHL_API_KEY=
GHL_LOCATION_ID=
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# TTL idempotency keys Redis (secondi). Default produzione: non impostare (usa default per chiave).
# In development impostare a 300 per far scadere velocemente e ripetere test senza cancellare Redis.
# Chiavi configurate: recovery_sms_sent (default 3600), fallback_done (default 86400), handoff_done (default 86400).
# IDEMPOTENCY_TTL_SECONDS=300

# QStash (Upstash) — scheduling chiamate a orario preciso
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# URL fisso del dominio di produzione Vercel (senza trailing slash).
# Usato dai callback QStash — NON usare VERCEL_URL che punta al preview deploy.
# Esempio: https://elevate-noleggio-pro.vercel.app
PUBLIC_BASE_URL=https://elevate-noleggio-pro.vercel.app

# Solo per test locali: bypassa verifica firma QStash. MAI true in produzione.
# SKIP_QSTASH_SIGNATURE_CHECK=true
